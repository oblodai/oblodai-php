{
    "name": "oblodai/sdk",
    "description": "Официальный PHP SDK для платёжного шлюза Oblodai: приём платежей, выплаты, статические кошельки, вебхуки.",
    "type": "library",
    "license": "MIT",
    "keywords": ["oblodai", "crypto", "payments", "payout", "cryptocurrency", "usdt", "webhook", "payment-gateway"],
    "homepage": "https://github.com/oblodai/oblodai-php",
    "authors": [
        { "name": "Oblodai" }
    ],
    "require": {
        "php": ">=8.0",
        "ext-json": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0"
    },
    "autoload": {
        "psr-4": { "Oblodai\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "Oblodai\\Tests\\": "tests/" }
    },
    "support": {
        "issues": "https://github.com/oblodai/oblodai-php/issues",
        "source": "https://github.com/oblodai/oblodai-php"
    },
    "config": {
        "sort-packages": true
    }
}
